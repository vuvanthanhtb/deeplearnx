# ============================================================
# PostgreSQL (cài trực tiếp trên server)
# DB_HOST không cần thay đổi nếu dùng host-gateway
# ============================================================
DB_PORT=5432
DB_NAME=deeplearnx_db
DB_USERNAME=devuser
DB_PASSWORD=change_me_in_production

# ============================================================
# Spring Boot
# validate | update | create | create-drop  (khuyến nghị update trên prod)
# ============================================================
SPRING_JPA_DDL_AUTO=update

# ============================================================
# JWT
# ============================================================
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ============================================================
# CORS - thay bằng domain thực của frontend
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost

# ============================================================
# Super admin
# ============================================================
SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=superadmin@deeplearnx.com
SUPERADMIN_PASSWORD=change_me_in_production
SUPERADMIN_FULLNAME=Super Admin
