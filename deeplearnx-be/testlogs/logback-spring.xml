<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ====== Properties ====== -->
  <property name="log_path"       value="logs"/>
  <property name="log_name"       value="deeplearnx"/>
  <property name="log_error_name" value="deeplearnx_error"/>

  <property name="PATTERN_CONSOLE"
    value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%-5p) %clr([%X{requestId:- -}]){blue} %clr([%X{userLogin:-anonymous}]){yellow} %clr([%15.15t]){faint} %clr(%-40.40logger{36}){cyan} : %msg%n%ex{full}"/>

  <property name="PATTERN_FILE"
    value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5p [%X{requestId:- -}] [%X{userLogin:-anonymous}] [%t] %-40.40logger{36} : %msg%n%ex{full}"/>

  <!-- ====== Console Appender ====== -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${PATTERN_CONSOLE}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ====== File Appender (all levels) ====== -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${log_path}/${log_name}.txt</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${log_path}/${log_name}.%d{yyyy-MM-dd}.%i.txt.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
      <maxFileSize>100MB</maxFileSize>
      <totalSizeCap>3GB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${PATTERN_FILE}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ====== Error-only File Appender ====== -->
  <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${log_path}/${log_error_name}.txt</file>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>ERROR</level>
    </filter>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${log_path}/${log_error_name}.%d{yyyy-MM-dd}.%i.txt.gz</fileNamePattern>
      <maxHistory>30</maxHistory>
      <maxFileSize>50MB</maxFileSize>
      <totalSizeCap>500MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>${PATTERN_FILE}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ====== Async wrappers (used in prod) ====== -->
  <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="FILE"/>
    <queueSize>512</queueSize>
    <neverBlock>true</neverBlock>
    <includeCallerData>false</includeCallerData>
  </appender>

  <appender name="ASYNC_FILE_ERROR" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="FILE_ERROR"/>
    <queueSize>256</queueSize>
    <neverBlock>true</neverBlock>
    <includeCallerData>false</includeCallerData>
  </appender>

  <!-- ====== Root: always write to console + file ====== -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="FILE"/>
    <appender-ref ref="FILE_ERROR"/>
  </root>

  <!-- ====== Log levels by profile ====== -->
  <springProfile name="prod">
    <logger name="com.deeplearnx"    level="INFO"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
  </springProfile>

  <springProfile name="!prod">
    <logger name="com.deeplearnx"    level="DEBUG"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
  </springProfile>

</configuration>
