<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ====== Properties ====== -->
  <property name="log_path" value="logs/" />
  <property name="log_name" value="deeplearnx" />
  <property name="log_error_name" value="deeplearnx_error" />

  <!-- ====== Console Appender ====== -->
  <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>
        %d{yyyy-MM-dd HH:mm:ss} - %mdc{trace_id} - %mdc{span_id} - ${log_name}
        - %X{g_requestId} - %X{userLogin} - %X{requestId}
        - [%t] %p --- %c{1} : %msg %replace(%ex){'[\r\n]+', ''}%nopex%n
      </pattern>
    </encoder>
    <target>System.out</target>
  </appender>

  <!-- ====== File Appender ====== -->
  <appender name="file" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${log_path}/${log_name}.log</file>

    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <!-- daily rollover -->
      <fileNamePattern>
        ${log_path}/${log_name}.%d{yyyy-MM-dd}.%i.gz
      </fileNamePattern>
      <maxHistory>30</maxHistory>
      <MaxFileSize>100MB</MaxFileSize>
    </rollingPolicy>

    <encoder>
      <pattern>
        %d{yyyy-MM-dd HH:mm:ss} - %mdc{trace_id} - %mdc{span_id} - ${log_name}
        - %X{g_requestId} - %X{userLogin} - %X{requestId}
        - [%t] %p --- %c{1} : %msg %replace(%ex){'[\r\n]+', ''}%nopex%n
      </pattern>
    </encoder>
  </appender>

  <!-- ====== Error File Appender ====== -->
  <appender name="file_error" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${log_path}/${log_error_name}.log</file>

    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>ERROR</level>
    </filter>

    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <!-- daily rollover -->
      <fileNamePattern>
        ${log_path}/${log_error_name}.%d{yyyy-MM-dd}.%i.gz
      </fileNamePattern>
      <maxHistory>30</maxHistory>
      <MaxFileSize>2MB</MaxFileSize>
    </rollingPolicy>

    <encoder>
      <pattern>
        %d{yyyy-MM-dd HH:mm:ss} - %mdc{trace_id} - %mdc{span_id} - ${log_name}
        - %X{g_requestId} - %X{userLogin} - %X{requestId}
        - [%t] %p --- %c{1} : %msg %replace(%ex){'[\r\n]+', ''}%nopex%n
      </pattern>
    </encoder>
  </appender>

  <!-- ====== Root Logger ====== -->
  <root level="info">
    <appender-ref ref="console"/>
  </root>

</configuration>